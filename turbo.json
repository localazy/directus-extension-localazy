{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build:scripts": {
      "outputs": ["src/config/config.json"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build:scripts", "^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build:scripts"],
      "persistent": true,
      "interruptible": true,
      "cache": false
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "format": {
      "outputs": [],
      "cache": true
    },
    "format:fix": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build:scripts"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build:scripts"],
      "outputs": [],
      "cache": true
    }
  }
}
