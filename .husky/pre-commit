# If nvm is available, source it and use the version pinned in .nvmrc.
# ESLint 10's stylish formatter requires Node 22.18+ (util.styleText). Without
# this, contributors whose globally-active Node is older hit "util.styleText is
# not a function" the moment lint-staged runs eslint against staged files.
NVM_DIR_PATH="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR_PATH/nvm.sh" ]; then
  . "$NVM_DIR_PATH/nvm.sh"
  nvm use --silent >/dev/null 2>&1
fi

npx lint-staged
