{
  "name": "directus-extension-localazy",
  "description": "A monorepo for Localazy Directus extensions",
  "version": "1.0.10",
  "keywords": [
    "directus",
    "directus-extension",
    "directus translation",
    "directus localization",
    "localazy"
  ],
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "extensions/common",
    "extensions/module",
    "extensions/sync-hook"
  ],
  "scripts": {
    "build": "npm run build-scripts && npm run build:module && npm run build:hook",
    "build:development": "npm run build:module && npm run build:hook",
    "build:module": "npm run build --workspace=@localazy/directus-extension-localazy -- --no-minify",
    "build:hook": "npm run build --workspace=@localazy/directus-extension-localazy-automation -- --no-minify",
    "dev": "node ./scripts/dev.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "build-scripts": "npm run set-production-config && node ./scripts/copy-license.mjs",
    "set-production-config": "npm run set-config -- --mode=production",
    "set-config": "node ./scripts/set-config.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.12.11",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "@vue/eslint-config-airbnb": "^7.0.0",
    "better-sqlite3": "^11.10.0",
    "directus": "^11.17.4",
    "eslint": "^8.44.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-vue": "^9.15.1",
    "typescript": "^5.4.5"
  }
}
