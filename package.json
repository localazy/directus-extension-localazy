{
  "name": "directus-extension-localazy",
  "description": "A monorepo for Localazy Directus extensions",
  "version": "2.2.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus translation",
    "directus localization",
    "localazy"
  ],
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build && node ./scripts/copy-license.mjs",
    "build:development": "turbo run build -- --no-minify",
    "dev": "node ./scripts/dev.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "turbo run typecheck --continue",
    "test": "turbo run test --continue",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "check": "pnpm run lint && pnpm run format && turbo run typecheck test --continue",
    "check:fix": "pnpm run lint:fix && pnpm run format:fix",
    "set-production-config": "pnpm --filter=@localazy/directus-common run build:scripts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "better-sqlite3": "^12.0.0",
    "directus": "^12.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "knip": "^6.12.2",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.8"
  }
}
