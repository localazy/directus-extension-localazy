{
  "name": "directus-extension-localazy",
  "description": "A monorepo for Localazy Directus extensions",
  "version": "1.0.10",
  "keywords": [
    "directus",
    "directus-extension",
    "directus translation",
    "directus localization",
    "localazy"
  ],
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "extensions/common",
    "extensions/module",
    "extensions/sync-hook"
  ],
  "scripts": {
    "build": "npm run build-scripts && npm run build:module && npm run build:hook",
    "build:development": "npm run build:module:dev && npm run build:hook:dev",
    "build:module": "npm run build --workspace=@localazy/directus-extension-localazy",
    "build:hook": "npm run build --workspace=@localazy/directus-extension-localazy-automation",
    "build:module:dev": "npm run build --workspace=@localazy/directus-extension-localazy -- --no-minify",
    "build:hook:dev": "npm run build --workspace=@localazy/directus-extension-localazy-automation -- --no-minify",
    "dev": "node ./scripts/dev.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run format && npm run test",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "build-scripts": "npm run set-production-config && node ./scripts/copy-license.mjs",
    "set-production-config": "npm run set-config -- --mode=production",
    "set-config": "node ./scripts/set-config.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.0.0",
    "directus": "^11.17.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.8"
  }
}
