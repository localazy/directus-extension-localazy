{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/*.scss"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "ignoreDependencies": ["directus", "better-sqlite3"]
    },
    "packages/module": {
      "entry": ["src/index.ts"],
      "ignoreDependencies": ["sass"]
    },
    "packages/sync-hook": {
      "entry": ["src/hook/index.ts", "src/endpoint/index.ts"]
    }
  }
}
